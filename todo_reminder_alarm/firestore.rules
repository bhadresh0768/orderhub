rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'admin';
    }

    function isDeliveryBoy() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'deliveryBoy';
    }

    function myPhone() {
      return userDoc(request.auth.uid).data.phoneNumber;
    }

    function myBusinessId() {
      return userDoc(request.auth.uid).data.businessId;
    }

    function isBusinessOwnerOf(businessId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function isOrderLocked() {
      return resource.data.status == 'completed' ||
        (resource.data.delivery is map &&
          resource.data.delivery.status == 'delivered');
    }

    function isRequesterOfOrder() {
      return signedIn() && resource.data.customerId == request.auth.uid;
    }

    function requesterCanEditPendingOrder() {
      return isRequesterOfOrder() &&
        resource.data.status == 'pending' &&
        resource.data.delivery.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'priority',
          'items',
          'deliveryAddressLabel',
          'deliveryAddress',
          'deliveryContactName',
          'deliveryContactPhone',
          'payment',
          'notes',
          'updatedAt'
        ]) &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.delivery == resource.data.delivery &&
        request.resource.data.payment.status == resource.data.payment.status &&
        request.resource.data.payment.amount == resource.data.payment.amount &&
        request.resource.data.payment.collectedBy == resource.data.payment.collectedBy &&
        request.resource.data.payment.collectedByName == resource.data.payment.collectedByName;
    }

    function businessOwnerCanFinalizePaymentOnLockedOrder() {
      return signedIn() &&
        isBusinessOwnerOf(resource.data.businessId) &&
        isOrderLocked() &&
        resource.data.payment.status != 'done' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'payment',
          'updatedAt'
        ]) &&
        request.resource.data.payment.status == 'done';
    }

    function categoryBelongsTo(businessId, categoryId) {
      return categoryId == null ||
        (exists(/databases/$(database)/documents/catalogCategories/$(categoryId)) &&
          get(/databases/$(database)/documents/catalogCategories/$(categoryId)).data.businessId == businessId);
    }

    function productBelongsTo(businessId, productId) {
      return exists(/databases/$(database)/documents/catalogProducts/$(productId)) &&
        get(/databases/$(database)/documents/catalogProducts/$(productId)).data.businessId == businessId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && isAdmin();
      allow delete: if isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (
        signedIn() &&
        request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isAdmin() || isBusinessOwnerOf(businessId) || (
        signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['orderCounter', 'updatedAt']) &&
        request.resource.data.orderCounter is int &&
        (
          (resource.data.orderCounter is int && request.resource.data.orderCounter == resource.data.orderCounter + 1) ||
          (!(resource.data.orderCounter is int) && request.resource.data.orderCounter >= 1)
        )
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (
        signedIn() && (
          resource.data.customerId == request.auth.uid ||
          isBusinessOwnerOf(resource.data.businessId) ||
          (isDeliveryBoy() && resource.data.assignedDeliveryAgentPhone == myPhone())
        )
      );
      allow create: if signedIn() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() ||
        businessOwnerCanFinalizePaymentOnLockedOrder() || (
          !isOrderLocked() &&
          signedIn() && (
            isBusinessOwnerOf(resource.data.businessId) ||
            requesterCanEditPendingOrder() ||
            (
              isDeliveryBoy() &&
              resource.data.assignedDeliveryAgentPhone == myPhone() &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['delivery', 'status', 'payment', 'updatedAt'])
            )
          )
        );
      allow delete: if isAdmin() || (
        isRequesterOfOrder() &&
        resource.data.status == 'pending' &&
        resource.data.delivery.status == 'pending'
      );
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || (
        signedIn() && resource.data.userId == request.auth.uid
      );
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'open';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /contactUs/{entryId} {
      allow read: if isAdmin() || (
        signedIn() && resource.data.userId == request.auth.uid
      );
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /subscriptionRenewalRequests/{businessId} {
      allow read: if isAdmin() || (
        signedIn() && resource.data.ownerId == request.auth.uid
      );
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.businessId == businessId &&
        isBusinessOwnerOf(businessId) &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.status == 'pending'
      );
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
      allow create: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId is string &&
        isBusinessOwnerOf(request.resource.data.businessId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId == resource.data.businessId &&
        isBusinessOwnerOf(resource.data.businessId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /quoteCustomers/{customerId} {
      allow read: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
      allow create: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId is string &&
        isBusinessOwnerOf(request.resource.data.businessId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId == resource.data.businessId &&
        isBusinessOwnerOf(resource.data.businessId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /quoteItemNames/{itemId} {
      allow read: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
      allow create: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId is string &&
        request.resource.data.businessId.size() > 0 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        isBusinessOwnerOf(request.resource.data.businessId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId is string &&
        request.resource.data.businessId.size() > 0 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.businessId == resource.data.businessId &&
        isBusinessOwnerOf(resource.data.businessId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /item_catalog/{itemId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /deliveryAgents/{agentId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || (
        signedIn() && (
          request.resource.data.businessId == myBusinessId() ||
          isBusinessOwnerOf(request.resource.data.businessId)
        )
      );
      allow delete: if isAdmin();
    }

    match /deliveryAddresses/{addressId} {
      allow read: if isAdmin() || (
        signedIn() && resource.data.userId == request.auth.uid
      );
      allow create: if isAdmin() || (
        signedIn() && request.resource.data.userId == request.auth.uid
      );
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin() || (
        signedIn() && resource.data.userId == request.auth.uid
      );
    }

    match /orderCounters/{businessId} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.data.businessId == businessId &&
        request.resource.data.value is int &&
        request.resource.data.value >= 1 &&
        (
          (!exists(/databases/$(database)/documents/orderCounters/$(businessId)) && request.resource.data.value == 1) ||
          (exists(/databases/$(database)/documents/orderCounters/$(businessId)) &&
            request.resource.data.value == resource.data.value + 1)
        );
      allow delete: if isAdmin();
    }

    match /catalogCategories/{categoryId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(request.resource.data.businessId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId == resource.data.businessId &&
        isBusinessOwnerOf(resource.data.businessId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /catalogProducts/{productId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (
        signedIn() &&
        isBusinessOwnerOf(request.resource.data.businessId) &&
        categoryBelongsTo(request.resource.data.businessId, request.resource.data.categoryId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId == resource.data.businessId &&
        isBusinessOwnerOf(resource.data.businessId) &&
        categoryBelongsTo(resource.data.businessId, request.resource.data.categoryId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /catalogVariants/{variantId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (
        signedIn() &&
        isBusinessOwnerOf(request.resource.data.businessId) &&
        request.resource.data.productId is string &&
        productBelongsTo(request.resource.data.businessId, request.resource.data.productId)
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.productId == resource.data.productId &&
        isBusinessOwnerOf(resource.data.businessId) &&
        productBelongsTo(resource.data.businessId, resource.data.productId)
      );
      allow delete: if isAdmin() || (
        signedIn() && isBusinessOwnerOf(resource.data.businessId)
      );
    }

    match /orderUnits/{unitCode} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
